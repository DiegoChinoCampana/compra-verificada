{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm run setup",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[...slug].ts": {
      "maxDuration": 60,
      "includeFiles": "server/db/**"
    }
  }
}
