{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm run setup",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/articulos", "destination": "/index.html" },
    { "source": "/articulos/:path*", "destination": "/index.html" },
    { "source": "/tableros", "destination": "/index.html" },
    { "source": "/tableros/(.*)", "destination": "/index.html" },
    { "source": "/informe", "destination": "/index.html" },
    { "source": "/informe/:path*", "destination": "/index.html" },
    { "source": "/resumen", "destination": "/index.html" },
    { "source": "/resumen/:path*", "destination": "/index.html" },
    { "source": "/listados", "destination": "/index.html" },
    { "source": "/listados/(.*)", "destination": "/index.html" },
    { "source": "/resultados", "destination": "/index.html" },
    { "source": "/resultados/:path*", "destination": "/index.html" },
    { "source": "/analisis", "destination": "/index.html" },
    { "source": "/analisis/:path*", "destination": "/index.html" },
    { "source": "/guia-hot-sale", "destination": "/index.html" },
    { "source": "/guia-hot-sale/:path*", "destination": "/index.html" },
    { "source": "/operacion/:path*", "destination": "/index.html" },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[...slug].ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/articles/[id].ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/articles/[id]/results.ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/analytics/article/[articleId]/[metric].ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/analytics/peers/by-article-detail.ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/analytics/operational/stale-scrapes.ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/analytics/operational/missing-recent-results.ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/analytics/operational/product-clustering-meta.ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/analytics/operational/product-clustering-run.ts": {
      "maxDuration": 300,
      "includeFiles": "server/dist/**"
    },
    "api/analysis/[...path].ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/report/article/[articleId].ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/report/hot-sale-roundup.ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/test-db.ts": {
      "maxDuration": 30
    },
    "api/debug.ts": {
      "maxDuration": 30
    },
    "api/meta/whatsapp/webhook.ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/routes.ts": {
      "maxDuration": 30
    },
    "api/tableros/[...path].ts": {
      "maxDuration": 30
    },
    "api/informe/[...path].ts": {
      "maxDuration": 30
    },
    "api/listados/[...path].ts": {
      "maxDuration": 30
    }
  }
}
