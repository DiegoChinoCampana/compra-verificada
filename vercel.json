{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm run setup",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "src/index.ts": {
      "maxDuration": 120,
      "includeFiles": "server/dist/**"
    },
    "api/test-db.ts": {
      "maxDuration": 30
    }
  }
}
