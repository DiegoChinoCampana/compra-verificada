# Copiar a server/.env
#
# 1) Base vacía: una vez `npm run db:ensure` (desde la raíz) crea DB_NAME si no existe
#    (conecta a POSTGRES_ADMIN_DB, por defecto "postgres").
# 2) Tablas: al arrancar la API se aplica el esquema IPC (SQL embebido en build desde db/schema.sql). Para saltarlo: SKIP_DB_SCHEMA=1

DB_HOST=localhost
DB_PORT=5432
DB_NAME=compra_verificada
# En macOS con Postgres por Homebrew suele ser tu usuario del sistema, no "postgres"
DB_USER=tu_usuario_sistema
DB_PASSWORD=

# Solo usado por npm run db:ensure (conexión a una base que ya exista)
POSTGRES_ADMIN_DB=postgres

# Opcional (si está definida, tiene prioridad sobre DB_* para la app)
# DATABASE_URL=postgresql://postgres:pass@localhost:5432/compra_verificada
#
# Postgres remoto (Vercel / servidor en la nube): suele hacer falta SSL en DATABASE_URL (?sslmode=require).
# Si el certificado del servidor es propio / autofirmado y Node falla con "self signed certificate":
# PGSSL_REJECT_UNAUTHORIZED=false
# PGSSLMODE=require

PORT=3001
# SKIP_DB_SCHEMA=1

# --- Clustering / embeddings (OpenAI) ---
# Crear clave en https://platform.openai.com/api-keys — no commitear server/.env
OPENAI_API_KEY=
# Opcional: si tu organización usa proyectos (cabecera OpenAI-Project)
# OPENAI_PROJECT_ID=proj_...
# OPENAI_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
#
# Fusión extra post-DBSCAN (centroides): acerca listados del mismo producto en clusters distintos
# CLUSTER_CENTROID_MERGE_MIN_SIMILARITY=0.92
# CLUSTER_SKIP_CENTROID_MERGE=1
# Fusión adicional: une clusters si algún par de listados (uno en cada cluster) supera el umbral (= centroid por defecto)
# CLUSTER_SKIP_PAIRWISE_MERGE=1
